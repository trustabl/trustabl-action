{
  "name": "trustabl-action",
  "version": "0.2.0",
  "private": true,
  "description": "Static reliability/safety scanner for AI agent repos (Claude, OpenAI, Google ADK, MCP) — GitHub Action.",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/main.ts -o dist --license licenses.txt",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "all": "npm run typecheck && npm test && npm run build"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@actions/artifact": "^2.1.11",
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@actions/tool-cache": "^2.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "@vercel/ncc": "^0.38.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.5.3"
  }
}
